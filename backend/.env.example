# Django
SECRET_KEY=change-me-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
USE_SQLITE=True
TIME_ZONE=Asia/Dhaka

# Database (production — Railway/Render)
# DATABASE_URL=postgresql://...

# CORS (production frontend URL)
# CORS_ALLOWED_ORIGINS=https://your-site.netlify.app

# ─── Email (pick ONE backend) ───────────────────────────────
#
# PRODUCTION (Railway/Render free tier blocks SMTP ports 587/465):
# Option A — Brevo (recommended; verify your Gmail as sender at brevo.com)
BREVO_API_KEY=
EMAIL_HOST_USER=your@gmail.com
#
# Option B — Resend (requires a verified domain at resend.com)
# RESEND_API_KEY=
# DEFAULT_FROM_EMAIL=Life Engine <noreply@yourdomain.com>
#
# LOCAL DEV ONLY — Gmail SMTP with App Password:
# EMAIL_HOST_USER=your@gmail.com
# EMAIL_HOST_PASSWORD=your16charapppassword
